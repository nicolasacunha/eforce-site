{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "eforce.com.br" }],
      "destination": "https://eforcedrums.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.eforce.com.br" }],
      "destination": "https://eforcedrums.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
